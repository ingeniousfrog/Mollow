{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mollow.dev/schemas/machine-snapshot-v4.schema.json",
  "title": "Mollow Machine Snapshot v4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mollow_version",
    "captured_at_unix_ms",
    "system",
    "cpu",
    "memory",
    "storage",
    "gpu",
    "media",
    "power",
    "thermal",
    "runtimes",
    "hardware_context",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "4.0.0"
    },
    "mollow_version": {
      "type": "string",
      "minLength": 1
    },
    "captured_at_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "system": {
      "$ref": "#/$defs/genericCapability"
    },
    "cpu": {
      "$ref": "#/$defs/genericCapability"
    },
    "memory": {
      "$ref": "#/$defs/memoryCapability"
    },
    "storage": {
      "$ref": "#/$defs/genericCapability"
    },
    "gpu": {
      "$ref": "#/$defs/gpuCapability"
    },
    "media": {
      "$ref": "#/$defs/mediaCapability"
    },
    "power": {
      "$ref": "#/$defs/powerCapability"
    },
    "thermal": {
      "$ref": "#/$defs/thermalCapability"
    },
    "runtimes": {
      "$ref": "#/$defs/genericCapability"
    },
    "hardware_context": {
      "$ref": "#/$defs/hardwareContextCapability"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "status": {
      "enum": [
        "available",
        "unsupported",
        "permission_denied",
        "unavailable",
        "error"
      ]
    },
    "source": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "provider",
        "detail"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "genericCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {},
        "source": {
          "$ref": "#/$defs/source"
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "memoryCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/memoryInfo"
            }
          ]
        }
      }
    },
    "hardwareContextCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/hardwareContext"
            }
          ]
        }
      }
    },
    "gpuCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/gpuInfo"
              }
            }
          ]
        }
      }
    },
    "mediaCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/mediaInfo"
            }
          ]
        }
      }
    },
    "powerCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/powerInfo"
            }
          ]
        }
      }
    },
    "thermalCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/thermalInfo"
            }
          ]
        }
      }
    },
    "memoryInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bytes",
        "available_bytes",
        "swap",
        "modules"
      ],
      "properties": {
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "available_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "swap": {
          "$ref": "#/$defs/genericCapability"
        },
        "modules": {
          "$ref": "#/$defs/memoryModulesCapability"
        }
      }
    },
    "memoryModulesCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/memoryModuleInfo"
              }
            }
          ]
        }
      }
    },
    "memoryModuleInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot",
        "mem_type",
        "speed_mts",
        "size_bytes",
        "manufacturer"
      ],
      "properties": {
        "slot": {
          "type": [
            "string",
            "null"
          ]
        },
        "mem_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "speed_mts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "size_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "manufacturer": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "hardwareContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_version",
        "cpu",
        "gpu",
        "memory",
        "benchmark_reference"
      ],
      "properties": {
        "catalog_version": {
          "type": "string"
        },
        "cpu": {
          "$ref": "#/$defs/cpuCatalogCapability"
        },
        "gpu": {
          "$ref": "#/$defs/gpuCatalogListCapability"
        },
        "memory": {
          "$ref": "#/$defs/memoryCatalogCapability"
        },
        "benchmark_reference": {
          "$ref": "#/$defs/benchmarkReferenceCapability"
        }
      }
    },
    "matchConfidence": {
      "enum": [
        "exact",
        "normalized",
        "fuzzy"
      ]
    },
    "cpuCatalogCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/cpuCatalogMatch"
            }
          ]
        }
      }
    },
    "gpuCatalogListCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/gpuCatalogMatch"
              }
            }
          ]
        }
      }
    },
    "memoryCatalogCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/memoryCatalogMatch"
            }
          ]
        }
      }
    },
    "benchmarkReferenceCapability": {
      "allOf": [
        {
          "$ref": "#/$defs/genericCapability"
        }
      ],
      "properties": {
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/benchmarkReferenceMatch"
            }
          ]
        }
      }
    },
    "cpuCatalogMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matched_model",
        "confidence",
        "codename",
        "architecture_family",
        "architecture_summary",
        "process_nm",
        "base_clock_mhz",
        "boost_clock_mhz",
        "l3_cache_mb",
        "tdp_watts",
        "performance_core_count",
        "efficiency_core_count",
        "reference_urls",
        "diagram_template",
        "reference_score"
      ],
      "properties": {
        "matched_model": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/matchConfidence"
        },
        "codename": {
          "type": [
            "string",
            "null"
          ]
        },
        "architecture_family": {
          "type": [
            "string",
            "null"
          ]
        },
        "architecture_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "process_nm": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "base_clock_mhz": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "boost_clock_mhz": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "l3_cache_mb": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tdp_watts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "performance_core_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "efficiency_core_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "reference_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diagram_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "gpuCatalogMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matched_model",
        "confidence",
        "codename",
        "architecture_family",
        "architecture_summary",
        "process_nm",
        "shader_units",
        "memory_type",
        "memory_bus_bits",
        "tdp_watts",
        "reference_urls",
        "diagram_template",
        "reference_score"
      ],
      "properties": {
        "matched_model": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/matchConfidence"
        },
        "codename": {
          "type": [
            "string",
            "null"
          ]
        },
        "architecture_family": {
          "type": [
            "string",
            "null"
          ]
        },
        "architecture_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "process_nm": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "shader_units": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "memory_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory_bus_bits": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tdp_watts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "reference_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diagram_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "memoryCatalogMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matched_profile",
        "confidence",
        "memory_type",
        "speed_mts",
        "channels",
        "architecture_summary",
        "reference_urls",
        "diagram_template"
      ],
      "properties": {
        "matched_profile": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/matchConfidence"
        },
        "memory_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "speed_mts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "channels": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "architecture_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diagram_template": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "benchmarkReferenceMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_benchmark_version",
        "score_source",
        "cpu_reference_score",
        "gpu_reference_score",
        "cpu_local_rate_per_second",
        "gpu_local_rate_per_second",
        "cpu_vs_reference_basis_points",
        "gpu_vs_reference_basis_points"
      ],
      "properties": {
        "catalog_benchmark_version": {
          "type": "string"
        },
        "score_source": {
          "type": "string"
        },
        "cpu_reference_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "gpu_reference_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "cpu_local_rate_per_second": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "gpu_local_rate_per_second": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "cpu_vs_reference_basis_points": {
          "type": [
            "integer",
            "null"
          ]
        },
        "gpu_vs_reference_basis_points": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "gpuInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "vendor",
        "driver_version",
        "memory_bytes",
        "apis"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "vendor": {
          "type": [
            "string",
            "null"
          ]
        },
        "driver_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "apis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "mediaInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "hardware_decode_codecs",
        "hardware_encode_codecs",
        "notes"
      ],
      "properties": {
        "backend": {
          "type": "string"
        },
        "hardware_decode_codecs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hardware_encode_codecs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "powerInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "battery_percent",
        "charging",
        "low_power_mode"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "battery_percent": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "charging": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "low_power_mode": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "thermalInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "temperature_milli_celsius",
        "sensor"
      ],
      "properties": {
        "state": {
          "type": "string"
        },
        "temperature_milli_celsius": {
          "type": [
            "integer",
            "null"
          ]
        },
        "sensor": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
