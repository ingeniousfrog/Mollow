{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mollow.dev/schemas/benchmark-run-v1.schema.json",
  "title": "Mollow Benchmark Run v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mollow_version",
    "started_at_unix_ms",
    "profile",
    "context",
    "cpu",
    "memory",
    "storage",
    "gpu",
    "media",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "mollow_version": {
      "type": "string",
      "minLength": 1
    },
    "started_at_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "profile": {
      "enum": [
        "quick",
        "standard"
      ]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "cpu": {
      "$ref": "#/$defs/workloadCapability"
    },
    "memory": {
      "$ref": "#/$defs/workloadCapability"
    },
    "storage": {
      "$ref": "#/$defs/workloadCapability"
    },
    "gpu": {
      "$ref": "#/$defs/pendingCapability"
    },
    "media": {
      "$ref": "#/$defs/pendingCapability"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "status": {
      "enum": [
        "available",
        "unsupported",
        "permission_denied",
        "unavailable",
        "error"
      ]
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "detail"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_profile",
        "machine_snapshot"
      ],
      "properties": {
        "build_profile": {
          "enum": [
            "debug",
            "release"
          ]
        },
        "machine_snapshot": {
          "$ref": "machine-snapshot-v2.schema.json"
        }
      }
    },
    "workloadCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/workload"
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "pendingCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "type": [
            "object",
            "null"
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload_id",
        "workload_version",
        "measurement",
        "warmup_iterations",
        "parameters",
        "samples",
        "summary"
      ],
      "properties": {
        "workload_id": {
          "type": "string",
          "minLength": 1
        },
        "workload_version": {
          "type": "integer",
          "minimum": 1
        },
        "measurement": {
          "type": "string",
          "minLength": 1
        },
        "warmup_iterations": {
          "type": "integer",
          "minimum": 0
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sample"
          }
        },
        "summary": {
          "$ref": "#/$defs/summary"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "elapsed_ns",
        "work_units",
        "rate_per_second"
      ],
      "properties": {
        "elapsed_ns": {
          "type": "integer",
          "minimum": 1
        },
        "work_units": {
          "type": "integer",
          "minimum": 1
        },
        "rate_per_second": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "median_rate_per_second",
        "median_absolute_deviation",
        "minimum_rate_per_second",
        "maximum_rate_per_second",
        "variation_basis_points"
      ],
      "properties": {
        "median_rate_per_second": {
          "type": "integer",
          "minimum": 0
        },
        "median_absolute_deviation": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_rate_per_second": {
          "type": "integer",
          "minimum": 0
        },
        "maximum_rate_per_second": {
          "type": "integer",
          "minimum": 0
        },
        "variation_basis_points": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
