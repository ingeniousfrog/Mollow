{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mollow.dev/schemas/machine-snapshot-v2.schema.json",
  "title": "Mollow Machine Snapshot v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mollow_version",
    "captured_at_unix_ms",
    "system",
    "cpu",
    "memory",
    "storage",
    "gpu",
    "media",
    "power",
    "thermal",
    "runtimes",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "mollow_version": {
      "type": "string",
      "minLength": 1
    },
    "captured_at_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "system": {
      "$ref": "#/$defs/systemCapability"
    },
    "cpu": {
      "$ref": "#/$defs/cpuCapability"
    },
    "memory": {
      "$ref": "#/$defs/memoryCapability"
    },
    "storage": {
      "$ref": "#/$defs/storageCapability"
    },
    "gpu": {
      "$ref": "#/$defs/pendingCapability"
    },
    "media": {
      "$ref": "#/$defs/pendingCapability"
    },
    "power": {
      "$ref": "#/$defs/pendingCapability"
    },
    "thermal": {
      "$ref": "#/$defs/pendingCapability"
    },
    "runtimes": {
      "$ref": "#/$defs/runtimeCapability"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "status": {
      "enum": [
        "available",
        "unsupported",
        "permission_denied",
        "unavailable",
        "error"
      ]
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "detail"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "systemCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/systemInfo"
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "cpuCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/cpuInfo"
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "memoryCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/memoryInfo"
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "storageCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/storageVolume"
              }
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "runtimeCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/runtimeInfo"
              }
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "swapCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/swapInfo"
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "pendingCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "value": {
          "type": [
            "object",
            "null"
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/source"
            }
          ]
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "systemInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_name",
        "os_version",
        "kernel_version",
        "architecture",
        "hostname"
      ],
      "properties": {
        "os_name": {
          "type": "string",
          "minLength": 1
        },
        "os_version": {
          "$ref": "#/$defs/nullableString"
        },
        "kernel_version": {
          "$ref": "#/$defs/nullableString"
        },
        "architecture": {
          "type": "string",
          "minLength": 1
        },
        "hostname": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "cpuInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "physical_cores",
        "logical_cores",
        "features"
      ],
      "properties": {
        "model": {
          "$ref": "#/$defs/nullableString"
        },
        "physical_cores": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "logical_cores": {
          "type": "integer",
          "minimum": 1
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "memoryInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bytes",
        "available_bytes",
        "swap"
      ],
      "properties": {
        "total_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "available_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "swap": {
          "$ref": "#/$defs/swapCapability"
        }
      }
    },
    "swapInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bytes",
        "used_bytes"
      ],
      "properties": {
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "used_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "storageVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "mount_point",
        "file_system",
        "total_bytes",
        "available_bytes",
        "read_only"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nullableString"
        },
        "mount_point": {
          "type": "string"
        },
        "file_system": {
          "$ref": "#/$defs/nullableString"
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "available_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "read_only": {
          "type": "boolean"
        }
      }
    },
    "runtimeInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
