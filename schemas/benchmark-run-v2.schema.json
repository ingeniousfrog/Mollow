{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mollow.dev/schemas/benchmark-run-v2.schema.json",
  "title": "Mollow Benchmark Run v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mollow_version",
    "started_at_unix_ms",
    "profile",
    "context",
    "cpu",
    "memory",
    "storage",
    "gpu",
    "media",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "mollow_version": {
      "type": "string"
    },
    "started_at_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "profile": {
      "enum": [
        "quick",
        "standard"
      ]
    },
    "context": {
      "type": "object",
      "required": [
        "build_profile",
        "machine_snapshot"
      ],
      "properties": {
        "build_profile": {
          "enum": [
            "debug",
            "release"
          ]
        },
        "machine_snapshot": {
          "$ref": "machine-snapshot-v3.schema.json"
        }
      }
    },
    "cpu": {
      "$ref": "#/$defs/capability"
    },
    "memory": {
      "$ref": "#/$defs/capability"
    },
    "storage": {
      "$ref": "#/$defs/capability"
    },
    "gpu": {
      "$ref": "#/$defs/capability"
    },
    "media": {
      "$ref": "#/$defs/capability"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value",
        "source",
        "message"
      ],
      "properties": {
        "status": {
          "enum": [
            "available",
            "unsupported",
            "permission_denied",
            "unavailable",
            "error"
          ]
        },
        "value": {},
        "source": {
          "type": [
            "object",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
